# MongoDB Connection
MONGODB_URI=mongodb+srv://username:password@cluster0.ih1tunm.mongodb.net/ReadCycle

# Server Configuration
PORT=3019
NODE_ENV=development

# Session Configuration
SESSION_SECRET=your-super-secret-key-here
SESSION_MAX_AGE=86400000  # 24 hours in milliseconds

# Security
TRUST_PROXY=1  # Set to 1 in production

# CORS Configuration
CORS_ORIGIN=http://localhost:3000  # Update this in production

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000  # 15 minutes
RATE_LIMIT_MAX=100  # Limit each IP to 100 requests per windowMs

# Google Books API
GOOGLE_BOOKS_API_KEY=your-google-books-api-key-here
